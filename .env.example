# Скопируйте этот файл в `.env` и заполните свои значения.
# Переменные окружения загружаются при старте приложения.

# API-ключ OpenRouter (https://openrouter.ai/keys)
# Оставьте пустым, чтобы использовать fallback-значения (тональность: "неопределен")
OPENROUTER_API_KEY=

# Настройки SMTP для отправки email с формы обратной связи (опционально)
# Если SMTP_HOST пуст — письма имитируются (логируются, но не отправляются)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@portfolio.dev
SMTP_TO=you@example.com

# Rate limiting: макс. количество обращений с одного IP в окне времени
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=3600
